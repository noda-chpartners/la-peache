---
const reserveUrl =
  'https://lapeache.v4.pos-s.net/reserve/?utm_source=ig&utm_medium=social&utm_content=link_in_bio&fbclid=PAZXh0bgNhZW0CMTEAc3J0YwZhcHBfaWQPOTM2NjE5NzQzMzkyNDU5AAGnlMP7mN7T8hdE5rf-zZoVrREewkmbEgp4Wr1K5FDyoczKLdKr3kiaDjviSmQ_aem_JF5sLKfroqeq87zzOEYXvA';
const instagramUrl =
  'https://www.instagram.com/la_peache_nail?igsh=MXJ4bmY4dXRpYW9hag%3D%3D&utm_source=qr';

const info = [
  { label: '店名', value: 'La Peache nail' },
  { label: '住所', value: '富山県富山市田中町', note: '※住所はご予約確定後にご案内しております。' },
  { label: '営業時間', value: '平日10:00 - 19:00' },
  { label: '営業時間', value: '土日祝10:00 - 17:00' },
  { label: '定休日', value: '火曜日/土曜日/祝日' },
  { label: '席数', value: '1席' },
];
---

<section id="access" class="section access">
  <div class="inner access-inner">
    <div class="access-info" data-animate="right">
      <p class="section-label">Access</p>
      <dl class="access-list">
        {
          info.map((row) => (
            <div class="access-row">
              <dt class="access-label">{row.label}</dt>
              <dd class="access-value">
                {row.value}
                {row.note && <span class="access-note">{row.note}</span>}
              </dd>
            </div>
          ))
        }
      </dl>
    </div>

    <div class="access-reserve" data-animate="left" data-animate-delay="150">
      <p class="section-label reserve-label">Reservation</p>
      <p class="reserve-title">ご予約・お問い合わせ</p>
      <p class="reserve-text">
        ご予約は予約ページ、<br />
        お問い合わせは Instagram より承っております。
      </p>

      <div class="reserve-buttons">
        <a class="reserve-button reserve-button--reserve" href={reserveUrl} target="_blank" rel="noopener">
          <span class="reserve-button-icon">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.4">
              <rect x="3" y="4.5" width="18" height="16" rx="2" />
              <path d="M3 9h18M8 2.5v4M16 2.5v4" stroke-linecap="round" />
            </svg>
          </span>
          <span class="reserve-button-label">予約ページへ</span>
        </a>
        <a class="reserve-button reserve-button--insta" href={instagramUrl} target="_blank" rel="noopener">
          <span class="reserve-button-icon">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6">
              <rect x="3" y="3" width="18" height="18" rx="5" />
              <circle cx="12" cy="12" r="4" />
              <circle cx="17.2" cy="6.8" r="1.1" fill="currentColor" stroke="none" />
            </svg>
          </span>
          <span class="reserve-button-label">Instagramでお問い合わせ</span>
        </a>
      </div>

      <p class="reserve-note">ご予約・お問い合わせは、お気軽にどうぞ。</p>
    </div>
  </div>
</section>

<style lang="scss">
  @use '../styles/variables' as *;
  @use '../styles/mixins' as *;

  .access-inner {
    display: flex;
    justify-content: space-between;
    align-items: stretch;
  }

  .access-info {
    width: 50%;
  }

  .access-list {
    margin-top: 24px;
  }

  .access-row {
    display: flex;
    margin-top: 14px;
    padding-bottom: 12px;
    border-bottom: 1px dashed var(--line);
  }

  .access-label {
    width: 90px;
    font-weight: normal;
    font-size: 13px;
    letter-spacing: 0.08em;
    color: var(--pink-deep);
  }

  .access-value {
    font-size: 14px;
    letter-spacing: 0.04em;
    color: var(--text);
  }

  .access-note {
    display: block;
    margin-top: 6px;
    font-size: 12px;
    letter-spacing: 0.02em;
    line-height: 1.6;
    color: var(--text-light);
  }

  .access-reserve {
    width: 44%;
    padding: 40px;
    border-radius: 16px;
    background: var(--pink-block);
    color: var(--white);
    text-align: center;
  }

  .reserve-label {
    color: var(--white);
  }

  .reserve-title {
    margin-top: 12px;
    font-size: 20px;
    letter-spacing: 0.08em;
  }

  .reserve-text {
    margin-top: 16px;
    font-size: 13px;
    line-height: 1.9;
  }

  .reserve-buttons {
    margin-top: 28px;
  }

  .reserve-button {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 320px;
    margin-top: 14px;
    margin-right: auto;
    margin-left: auto;
    padding: 13px 0;
    border-radius: 999px;
    background: var(--white);
    box-shadow: 0 8px 18px rgba(153, 100, 82, 0.12);
    transition: transform 0.25s ease;
  }

  .reserve-button:first-child {
    margin-top: 0;
  }

  .reserve-button:hover {
    transform: translateY(-2px);
  }

  .reserve-button-icon {
    display: grid;
    place-items: center;
  }

  .reserve-button--reserve .reserve-button-icon {
    color: var(--pink-deep);
  }

  .reserve-button--insta .reserve-button-icon {
    color: #d6519a;
  }

  .reserve-button-label {
    margin-left: 10px;
    font-size: 14px;
    letter-spacing: 0.06em;
    color: var(--text);
  }

  .reserve-note {
    margin-top: 22px;
    font-size: 12px;
    letter-spacing: 0.04em;
  }

  @include tablet {
    .access-inner {
      flex-direction: column;
    }

    .access-info {
      width: 100%;
    }

    .access-reserve {
      width: 100%;
      margin-top: 32px;
      padding: 32px 28px;
    }
  }

  @include sp {
    .access-list {
      margin-top: 18px;
    }

    .access-row {
      flex-direction: column;
      margin-top: 12px;
      padding-bottom: 10px;
    }

    .access-label {
      width: auto;
      font-size: 12px;
    }

    .access-value {
      margin-top: 4px;
      font-size: 13px;
    }

    .access-map {
      margin-top: 18px;
    }

    .access-map iframe {
      height: 200px;
    }

    .access-reserve {
      margin-top: 24px;
      padding: 28px 20px;
    }

    .reserve-title {
      font-size: 18px;
    }

    .reserve-text {
      margin-top: 12px;
      font-size: 12px;
    }

    .reserve-buttons {
      margin-top: 22px;
    }

    .reserve-button-label {
      font-size: 13px;
    }

    .reserve-note {
      margin-top: 18px;
      font-size: 11px;
    }
  }
</style>
