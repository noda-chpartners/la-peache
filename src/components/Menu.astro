---
import { Image } from 'astro:assets';

import handSimple from '../assets/item011.jpg';
import handTrend from '../assets/item012.jpg';
import handOmakase from '../assets/item013.png';
import footSimple from '../assets/item014.png';
import footDesign from '../assets/item015.png';

const menuGroups = [
  {
    category: 'Hand',
    courses: [
      {
        src: handSimple,
        name: 'Simple',
        price: '¥6,800',
      },
      {
        src: handTrend,
        name: 'Trend',
        price: '¥8,500',
      },
      {
        src: handOmakase,
        name: 'おまかせ',
        price: '¥9,500',
      },
    ],
  },
  {
    category: 'Foot',
    courses: [
      {
        src: footSimple,
        name: 'Simple',
        price: '¥7,500',
      },
      {
        src: footDesign,
        name: 'Design',
        price: '¥9,500',
      },
    ],
  },
];
---

<section id="menu" class="section menu">
  <div class="inner">
    <div class="menu-head" data-animate="up">
      <p class="section-label">Menu / Price</p>
      <p class="menu-sub">定額のデザインコース</p>
    </div>

    <div class="menu-body">
      {
        menuGroups.map((group, gi) => (
          <div class="menu-group" data-animate="up" data-animate-delay={String(gi * 100)}>
            <p class="menu-group-title">{group.category}</p>
            <ul class="menu-cards">
              {group.courses.map((course, index) => (
                <li class="menu-card" data-animate="up" data-animate-delay={String(gi * 100 + index * 100)}>
                  <div class="menu-card-thumb">
                    <Image src={course.src} alt={`${group.category} ${course.name}`} widths={[200, 320]} sizes="(min-width: 1025px) 320px, 90vw" />
                  </div>
                  <p class="menu-card-name">{course.name}</p>
                  <p class="menu-card-price">
                    {course.price}<span class="menu-card-unit"></span>
                  </p>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="menu-action" data-animate="up" data-animate-delay="300">
      <a class="button" href="https://lapeache.v4.pos-s.net/reserve/?utm_source=ig&utm_medium=social&utm_content=link_in_bio&fbclid=PAZXh0bgNhZW0CMTEAc3J0YwZhcHBfaWQPOTM2NjE5NzQzMzkyNDU5AAGnlMP7mN7T8hdE5rf-zZoVrREewkmbEgp4Wr1K5FDyoczKLdKr3kiaDjviSmQ_aem_JF5sLKfroqeq87zzOEYXvA" target="_blank">メニューを見る</a>
    </div>
  </div>
</section>

<style lang="scss">
  @use '../styles/variables' as *;
  @use '../styles/mixins' as *;

  .menu-head {
    text-align: center;
  }

  .menu-sub {
    margin-top: 10px;
    font-size: 14px;
    letter-spacing: 0.06em;
    color: var(--text-light);
  }

  .menu-body {
    margin-top: 40px;
  }

  .menu-group {
    margin-top: 40px;
  }

  .menu-group:first-child {
    margin-top: 0;
  }

  .menu-group-title {
    font-family: var(--serif);
    font-size: 20px;
    letter-spacing: 0.1em;
    text-align: center;
    color: var(--pink-deep);
  }

  .menu-cards {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    width: 100%;
    margin-top: 20px;
  }

  .menu-card {
    flex: 1;
    padding: 18px 16px 22px;
    border-radius: 14px;
    background: var(--pink-pale);
    text-align: center;
  }

  .menu-card-thumb img {
    width: 100%;
    height: 170px;
    border-radius: 10px;
    object-fit: cover;
  }

  .menu-card-name {
    margin-top: 16px;
    font-size: 16px;
    letter-spacing: 0.06em;
    color: var(--text);
  }

  .menu-card-price {
    margin-top: 14px;
    font-family: var(--serif);
    font-size: 26px;
    letter-spacing: 0.04em;
    color: var(--pink-deep);
  }

  .menu-card-unit {
    margin-left: 2px;
    font-size: 14px;
  }

  .menu-action {
    display: flex;
    justify-content: center;
    margin-top: 44px;
  }

  @include tablet {
    .menu-body {
      margin-top: 32px;
    }

    .menu-group {
      margin-top: 32px;
    }

    .menu-cards {
      gap: 16px;
    }

    .menu-card-thumb img {
      height: 140px;
    }

    .menu-action {
      margin-top: 32px;
    }
  }

  @include sp {
    .menu-sub {
      font-size: 13px;
    }

    .menu-body {
      margin-top: 24px;
    }

    .menu-group {
      margin-top: 28px;
    }

    .menu-group-title {
      font-size: 18px;
    }

    .menu-cards {
      flex-direction: column;
    }

    .menu-card {
      width: 100%;
      margin-top: 16px;
      padding: 16px 14px 20px;
    }

    .menu-card:first-child {
      margin-top: 0;
    }

    .menu-card-thumb img {
      height: 160px;
    }

    .menu-card-name {
      margin-top: 14px;
      font-size: 15px;
    }

    .menu-card-price {
      font-size: 24px;
    }

    .menu-action {
      margin-top: 28px;
    }
  }
</style>
